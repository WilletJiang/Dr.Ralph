{
  "project": "MathReasoningLab",
  "branchName": "ralph/mathbench-idea-exploration",
  "description": "Auto-research harness that sharpens a benchmark question into a review-ready idea before any implementation begins.",
  "problem": {
    "source": "user_or_agent",
    "question": "Can we improve MathBench-v2 with a reasoning-state selection mechanism that stays fully batched and GPU-parallel instead of relying on sequential reranking?",
    "successDefinition": [
      "Produce a concise, elegant idea with a crisp mechanism",
      "Keep the core computation compatible with large-scale GPU parallelism",
      "Show early evidence that the mechanism is real, necessary, and plausibly high-upside",
      "Respect the user's research background, resource limits, and explicit requirements"
    ],
    "nonGoals": [
      "Do not auto-start implementation in src/ before user review",
      "Do not rely on brute-force serial search or hidden ensembling",
      "Do not settle for a narrow follow-up tweak with weak novelty"
    ]
  },
  "researcherContext": {
    "required": true,
    "isComplete": false,
    "intakeFile": "research/intake.md",
    "backgroundSummary": "",
    "requirementsSummary": "",
    "availableResources": "",
    "collaborationPreferences": "",
    "lastUpdated": ""
  },
  "benchmark": {
    "name": "MathBench-v2",
    "primaryMetric": "accuracy",
    "secondaryMetrics": [
      "latency_ms",
      "train_compute_multiplier"
    ],
    "baselineScore": 71.4,
    "targetScore": 73.0,
    "comparisonTarget": "official_best",
    "constraints": [
      "No external data",
      "No hidden test-time ensembling",
      "No benchmark leakage",
      "Model size increase must stay under 5%",
      "Inference latency increase must stay under 10%"
    ]
  },
  "harness": {
    "ideaFile": "idea.md",
    "overviewFile": "research/overview.md",
    "literatureFile": "research/literature/review.md",
    "progressFile": "progress.txt",
    "explorationPlanFile": "experiments/early-exploration/plan.md",
    "explorationRoot": "experiments/early-exploration",
    "liveLogFile": "experiments/early-exploration/live-log.md",
    "iterationLogRoot": "experiments/early-exploration/agent-runs",
    "reviewMemoFile": "research/final-review.md",
    "implementationTargetDir": "src",
    "tuningRoot": "research/tuning",
    "automationBoundary": "user_review",
    "postReviewStagesRequireUser": true,
    "rules": [
      "Do not auto-start implementation before the user review gate is reached and unlocked by a human",
      "Do not start autonomous research until the user has provided research background and requirements",
      "Every exploration run must save commands, configs, logs, results, and interpretation",
      "idea.md must be revised whenever evidence changes the best current version of the idea",
      "The loop must stop once the idea is professionalized and ready for user review"
    ]
  },
  "automation": {
    "mode": "auto_research_only",
    "state": "running",
    "boundaryStage": "user_review",
    "userIntakeRequired": true,
    "stopWhen": [
      "review_memo_is_ready",
      "automation_state_becomes_awaiting_user_review",
      "the_best_current_idea_is_killed_by_evidence"
    ],
    "requiresUserInterventionFor": [
      "implementation",
      "benchmark_tuning"
    ],
    "notes": "Post-review implementation and benchmark tuning are intentionally outside the autonomous loop."
  },
  "taste": {
    "principles": [
      "Prefer the smallest sharp idea",
      "Reject kitchen-sink proposals",
      "One item should test one mechanism",
      "Complexity must earn its keep",
      "Negative evidence should kill weak ideas"
    ],
    "hardRules": [
      "If the mechanism cannot be explained crisply in 1-2 sentences, reject or simplify it",
      "If the method does not map cleanly to large-scale GPU parallel execution, reject or reformulate it",
      "If the novelty is only a narrow follow-up tweak without a qualitatively new mechanism, reject it",
      "If the idea would not clear an honest top-conference oral bar, sharpen it or kill it"
    ]
  },
  "officialResult": {
    "baselineScore": 71.4,
    "currentBestScore": 72.1,
    "currentBestItemId": "RI-000",
    "constraintsSatisfied": true,
    "notes": "Current best comes from verifier reranking with tuned temperature."
  },
  "userStories": [
    {
      "id": "RI-001",
      "stage": "problem_framing",
      "title": "Lock the exact research question and win condition",
      "hypothesis": "A sharper problem framing prevents the loop from wandering into metric gaming or low-upside novelty.",
      "deliverables": [
        "research/overview.md",
        "research_program.json"
      ],
      "constraints": [
        "Question may originate from the user or the agent, but it must be explicit",
        "Success conditions must be falsifiable and implementation-free at this stage"
      ],
      "acceptanceCriteria": [
        "Write the exact question, non-goals, and win condition",
        "Record the benchmark box and research constraints clearly",
        "Remove any ambiguity about what counts as success versus noise"
      ],
      "priority": 1,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": false,
      "notes": ""
    },
    {
      "id": "RI-002",
      "stage": "benchmark_overview",
      "title": "Map the benchmark landscape and bottlenecks",
      "hypothesis": "A careful benchmark overview will expose a narrow gap worth targeting before method design begins.",
      "deliverables": [
        "research/overview.md"
      ],
      "constraints": [
        "No method proposal beyond bottleneck hypotheses",
        "Must identify evaluation gotchas and scaling-relevant constraints"
      ],
      "acceptanceCriteria": [
        "Summarize baseline strengths and weaknesses",
        "Document likely bottleneck slices or failure clusters",
        "Record benchmark rules that would invalidate a fake win"
      ],
      "priority": 2,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": false,
      "notes": ""
    },
    {
      "id": "RI-003",
      "stage": "literature_review",
      "title": "Study the most relevant modern methods deeply",
      "hypothesis": "A targeted literature review will separate real mechanism gaps from cosmetic novelty opportunities.",
      "deliverables": [
        "research/literature/review.md"
      ],
      "constraints": [
        "Focus on the strongest relevant methods only",
        "Explain why each method may fail on this benchmark or under these systems constraints"
      ],
      "acceptanceCriteria": [
        "Document the strongest relevant prior methods",
        "Summarize each method's mechanism and limitation",
        "Identify at least one concrete gap worth testing"
      ],
      "priority": 3,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": false,
      "notes": ""
    },
    {
      "id": "RI-004",
      "stage": "idea_proposal",
      "title": "Write the first full idea.md",
      "hypothesis": "A strong initial idea can be stated before heavy experimentation if the problem and gap are sharp enough.",
      "deliverables": [
        "idea.md"
      ],
      "constraints": [
        "The idea must be concise, elegant, and mechanistically crisp",
        "The idea must support large-scale GPU parallel computation",
        "The idea must not merely be a narrow follow-up patch"
      ],
      "acceptanceCriteria": [
        "State the mechanism in 1-2 sentences",
        "Explain the novelty, parallel fit, falsification path, and oral-level claim honestly",
        "List the smallest decisive experiments"
      ],
      "priority": 4,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": false,
      "notes": ""
    },
    {
      "id": "RI-005",
      "stage": "validation_plan",
      "title": "Design the decisive early-exploration plan",
      "hypothesis": "A comprehensive but minimal validation plan can determine whether the idea deserves to survive.",
      "deliverables": [
        "experiments/early-exploration/plan.md",
        "experiments/early-exploration/live-log.md"
      ],
      "constraints": [
        "Plan the smallest set of decisive tests, not an unfocused sweep",
        "Explicitly define kill criteria and stop conditions"
      ],
      "acceptanceCriteria": [
        "Write the experiment plan, required artifacts, and decision thresholds",
        "Define what will be run in parallel versus sequentially",
        "Record what evidence would kill, revise, or promote the idea"
      ],
      "priority": 5,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": false,
      "notes": ""
    },
    {
      "id": "RI-006",
      "stage": "early_exploration",
      "title": "Execute the early-exploration plan under experiments/early-exploration",
      "hypothesis": "Small, decisive experiments can show whether the mechanism is real, necessary, and large enough to justify continued belief.",
      "deliverables": [
        "experiments/early-exploration/ri-006/",
        "experiments/early-exploration/live-log.md",
        "idea.md"
      ],
      "constraints": [
        "All commands, configs, logs, and interpretations must be saved",
        "Problems discovered during exploration must trigger explicit reasoning and refinement"
      ],
      "acceptanceCriteria": [
        "Run the planned decisive experiments",
        "Save raw evidence and a readable summary under the exploration root",
        "Update idea.md as evidence sharpens or weakens the mechanism"
      ],
      "priority": 6,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": false,
      "notes": ""
    },
    {
      "id": "RI-007",
      "stage": "idea_convergence",
      "title": "Stop exploration and professionalize the final idea package",
      "hypothesis": "Once the major unknowns are resolved, the best contribution is to converge the idea cleanly instead of continuing to explore.",
      "deliverables": [
        "idea.md",
        "research/final-review.md"
      ],
      "constraints": [
        "Do not leave loose experimental threads open without naming them",
        "Rewrite the idea in a professional, publication-ready style"
      ],
      "acceptanceCriteria": [
        "State the final best idea crisply and professionally",
        "Summarize the decisive evidence, revisions, and remaining risks",
        "Explicitly stop autonomous exploration once convergence is reached"
      ],
      "priority": 7,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": false,
      "notes": ""
    },
    {
      "id": "RI-008",
      "stage": "user_review",
      "title": "Hand the converged idea package to the user for review",
      "hypothesis": "A human review gate after idea convergence prevents the autonomous loop from drifting into implementation without approval.",
      "deliverables": [
        "research/final-review.md",
        "research_program.json"
      ],
      "constraints": [
        "The loop must stop here and wait for human input",
        "No automatic post-review work may begin"
      ],
      "acceptanceCriteria": [
        "Set automation.state to awaiting_user_review",
        "Point the user to the final review memo and idea.md",
        "Leave a clear next-step suggestion for the human reviewer"
      ],
      "priority": 8,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": false,
      "notes": ""
    },
    {
      "id": "RI-009",
      "stage": "implementation",
      "title": "Implement the reviewed idea in src/",
      "hypothesis": "Only a reviewed and approved idea should move into code.",
      "deliverables": [
        "src/"
      ],
      "constraints": [
        "This stage is outside the autonomous loop",
        "Requires explicit user approval after review"
      ],
      "acceptanceCriteria": [
        "Human reviewer unlocks the stage",
        "Implementation matches the approved idea.md",
        "No unrelated new methods are smuggled in"
      ],
      "priority": 9,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": true,
      "notes": ""
    },
    {
      "id": "RI-010",
      "stage": "benchmark_tuning",
      "title": "Integrate and tune only after reviewed implementation exists",
      "hypothesis": "Tuning should happen only after the human approves both the idea and the implementation path.",
      "deliverables": [
        "research/tuning/",
        "research_program.json"
      ],
      "constraints": [
        "This stage is outside the autonomous loop",
        "No metric gaming or hidden scaling"
      ],
      "acceptanceCriteria": [
        "Human reviewer unlocks the stage",
        "Log all tuning runs and update officialResult only for verified wins",
        "Preserve benchmark rules and trustworthiness"
      ],
      "priority": 10,
      "status": "queued",
      "passes": false,
      "requiresUserIntervention": true,
      "notes": ""
    }
  ]
}
