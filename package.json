{
  "name": "dr-ralph-cli",
  "version": "1.0.0",
  "description": "Agent-native CLI runtime for the Dr.Ralph autonomous research harness.",
  "type": "module",
  "bin": {
    "ralph": "./bin/ralph"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "research",
    "experiments",
    "prompt.md",
    "idea.md",
    "research_program.json.example",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli-bin.ts --format esm --target node20 --out-dir dist --clean",
    "dev": "tsx src/cli.ts",
    "smoke:codex-sdk": "tsx src/smoke/codex-sdk.ts",
    "smoke:mcp": "tsx src/smoke/mcp.ts",
    "smoke": "npm run smoke:mcp && npm run smoke:codex-sdk",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.121.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
